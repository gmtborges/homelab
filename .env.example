# Proxmox VE API token (user@realm!tokenid=secret) — create with:
#   pveum user token add terraform@pve provider --privsep=0
PROXMOX_VE_API_TOKEN=terraform@pve!provider=xxxxxxxx-xxxx-xxxx-xxxx-xxxxxxxxxxxx

# SSH public key injected into each VM's cloud-init user, e.g.:
#   export PROXMOX_VM_SSH_PUBLIC_KEY="$(cat ~/.ssh/id_ed25519.pub)"
PROXMOX_VM_SSH_PUBLIC_KEY="ssh-ed25519 AAAA... user@host"

# AWS profile for the Terragrunt S3 state backend (bucket: gbsoft-homelab-tfstate)
AWS_PROFILE=homelab
